{
  "name": "sorcery-omphalos",
  "private": true,
  "version": "0.1.0",
  "description": "A web app to play Sorcery: Contested Realm",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "predev": "npm run cards:split",
    "dev": "npm run dev --workspace apps/web",
    "build": "npm run cards:split && npm run build --workspace apps/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "cards:download": "python node_modules/@omphalos/cards/scripts/download_cards.py public",
    "cards:split": "node node_modules/@omphalos/cards/scripts/split-cards.mjs public"
  }
}
